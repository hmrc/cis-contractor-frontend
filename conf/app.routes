# Routes

# Infrastructure
->    /subcontractor/hmrc-frontend  hmrcfrontend.Routes

GET   /subcontractor  controllers.IndexController.onPageLoad()

GET   /subcontractor/assets/*file  controllers.Assets.versioned(path="/public", file: Asset)

GET   /language/:lang  controllers.LanguageSwitchController.switchToLanguage(lang: String)

GET   /subcontractor/refresh-session  controllers.KeepAliveController.keepAlive()

GET   /subcontractor/there-is-a-problem  controllers.JourneyRecoveryController.onPageLoad(continueUrl: Option[RedirectUrl] ?= None)

GET   /subcontractor/account/sign-out-survey  controllers.auth.AuthController.signOut()
GET   /subcontractor/account/sign-out         controllers.auth.AuthController.signOutNoSurvey()

GET   /subcontractor/account/signed-out  controllers.auth.SignedOutController.onPageLoad()

GET   /subcontractor/unauthorised  controllers.UnauthorisedController.onPageLoad()

GET   /subcontractor/unauthorised/organisation  controllers.UnauthorisedOrganisationAffinityController.onPageLoad()

GET   /subcontractor/unauthorised/individual  controllers.UnauthorisedIndividualAffinityController.onPageLoad()

GET   /subcontractor/unauthorised/agent  controllers.UnauthorisedAgentAffinityController.onPageLoad()

GET   /subcontractor/page-not-found  controllers.PageNotFoundController.onPageLoad()

GET   /subcontractor/access-denied  controllers.AccessDeniedController.onPageLoad()

GET   /subcontractor/system-error/there-is-a-problem  controllers.SystemErrorController.onPageLoad()

GET   /subcontractor/individual-address-lookup         controllers.add.AddressOfSubcontractorController.redirectToAddressLookup(mode: Mode = NormalMode, changeRoute: Option[String] ?= None)
GET   /subcontractor/individual-address-return         controllers.add.AddressOfSubcontractorController.addressLookupCallback(id: String ?= "", mode: Mode = NormalMode)
GET   /subcontractor/individual-address-return/change  controllers.add.AddressOfSubcontractorController.addressLookupCallbackChange(id: String ?= "", mode: Mode = NormalMode)

